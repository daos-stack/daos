# pylint: disable=consider-using-f-string
"""Build management server module"""


def scons():
    """Execute build"""
    Import('env', 'base_env', 'base_env_mpi', 'prereqs', 'libdaos_tgts', 'chk_pb')

    env.AppendUnique(LIBPATH=[Dir('.')])
    env.d_add_build_rpath()
    base_env.AppendUnique(LIBPATH=[Dir('.')])
    base_env.d_add_build_rpath()
    if base_env_mpi is not None:
        base_env_mpi.AppendUnique(LIBPATH=[Dir('.')])
        base_env_mpi.d_add_build_rpath()

    denv = env.Clone()

    denv.AppendUnique(CPPPATH=[Dir('.').srcnode(), Dir('..').srcnode()])

    denv.require('protobufc')

    pb_objs = denv.SharedObject(['acl.pb-c.c', 'pool.pb-c.c', 'svc.pb-c.c',
                                 'cont.pb-c.c', 'server.pb-c.c',
                                 'check.pb-c.c', 'shared/ranks.pb-c.c',
                                 'system.pb-c.c']) + chk_pb

    mgmt_rpc_lib = denv.d_library('daos_mgmt_rpc',
                                  denv.SharedObject(['rpc.c']) + pb_objs,
                                  LIBS=['daos_common', 'cart', 'gurt'])
    denv.Install('$PREFIX/lib64/', mgmt_rpc_lib)

    libdaos_tgts.extend(denv.SharedObject(['cli_mgmt.c', 'cli_query.c', 'cli_debug.c']))

    if not prereqs.server_requested():
        return

    senv = denv.Clone()
    senv.require('argobots', 'pmdk', headers_only=True)
    # Management server module
    senv.Append(CPPDEFINES=['-DDAOS_PMEM_BUILD'])
    srcs = [
        'mgmt_common.c',
        'srv_chk.c',
        'srv_container.c',
        'srv_drpc.c',
        'srv_layout.c',
        'srv_pool.c',
        'srv_query.c',
        'srv_system.c',
        'srv_target.c',
        'srv_util.c',
        'srv.c',
    ]
    mgmt_srv = senv.d_library('mgmt', srcs,
                              LIBS=['daos_mgmt_rpc', 'daos_common_pmem', 'cart', 'gurt'],
                              install_off='../..')
    senv.Install('$PREFIX/lib64/daos_srv', mgmt_srv)

    denv = senv
    if prereqs.test_requested():
        SConscript('tests/SConscript', exports=['denv', 'pb_objs'])


if __name__ == "SCons.Script":
    scons()
