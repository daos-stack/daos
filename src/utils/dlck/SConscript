"""Build tests"""


def scons():
    """Execute build"""
    Import('env', 'prereqs')

    denv = env.Clone()
    denv.Append(OBJPREFIX="dlck_")

    libs = ['vos_srv', 'daos_common_pmem', 'bio', 'uuid', 'gurt', 'pmemobj', 'abt']

    src = [
        'dlck_abt.c',
        'dlck_args_parser.c',
        'dlck_args.c',
        'dlck_common.c',
        'dlck_dtx_act_recs_recover.c',
        'dlck_engine.c',
        'dlck_main.c',
        'dlck_sched.c',
        'dlck_tls.c',
        'dlck_ult.c',
        'dlck_xstream.c',
        '../../mgmt/srv_util_simple.c',
    ]

    # Add runtime paths for daos libraries
    denv.AppendUnique(LIBPATH=[Dir('.')])
    denv.AppendUnique(RPATH_FULL=['$PREFIX/lib64/daos_srv'])
    denv.AppendUnique(RPATH_FULL=['$PREFIX/lib64'])

    prereqs.require(denv, 'argobots', 'pmdk')

    dlck = denv.d_program('dlck', src, LIBS=libs)
    env.Install('$PREFIX/bin', dlck)

    # build tests
    SConscript('tests/SConscript')


if __name__ == "SCons.Script":
    scons()
