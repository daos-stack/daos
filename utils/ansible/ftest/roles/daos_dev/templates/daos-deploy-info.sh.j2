#!/usr/bin/env bash
# shellcheck disable=all  # Jinja2 template — not parseable by shellcheck
#
# Deployment provenance — generated by ansible-playbook ftest.yml
# Do not edit by hand; re-run the playbook to refresh this file.
#
# Usage:
#   source daos-deploy-info.sh          # sets DAOS_* variables in the caller
#   ./daos-deploy-info.sh               # prints a human-readable summary
#                                       # including the saved inventory content

# ── When was the playbook run and from where ──────────────────────────────────
DAOS_GENERATED="{{ _deploy_timestamp }}"
DAOS_CONTROLLER_HOST="{{ _deploy_controller_host }}"
DAOS_CONTROLLER_USER="{{ _deploy_controller_user }}"
DAOS_ANSIBLE_VERSION="{{ _deploy_ansible_version }}"

# ── Inventory ─────────────────────────────────────────────────────────────────
# Path on the Ansible controller at the time the playbook was run.
DAOS_INVENTORY="{{ _deploy_inventory_path }}"
# Local copy saved to this node by the playbook.
DAOS_INVENTORY_COPY="{{ daos_runtime_dir }}/inventory.yml"

# ── Node groups ───────────────────────────────────────────────────────────────
DAOS_DEV_NODES="{{ groups["daos_dev"] | join(',') }}"
DAOS_SERVER_NODES="{{ groups["daos_servers"] | join(',') }}"
{% if "daos_clients" in groups and groups["daos_clients"] | length > 0 %}
DAOS_CLIENT_NODES="{{ groups["daos_clients"] | join(',') }}"
{% else %}
DAOS_CLIENT_NODES=""
{% endif %}

# ── When run directly (not sourced): print provenance summary ─────────────────
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "════════════════════════════════════════════════════════════════"
    echo "  DAOS Deployment Provenance"
    echo "════════════════════════════════════════════════════════════════"
    echo "  Generated       : ${DAOS_GENERATED}"
    echo "  Ansible version : ${DAOS_ANSIBLE_VERSION}"
    echo "  Controller host : ${DAOS_CONTROLLER_HOST}"
    echo "  Controller user : ${DAOS_CONTROLLER_USER}"
    echo "  Inventory path  : ${DAOS_INVENTORY}"
    echo ""
    echo "  Dev nodes    : ${DAOS_DEV_NODES}"
    echo "  Server nodes : ${DAOS_SERVER_NODES}"
    echo "  Client nodes : ${DAOS_CLIENT_NODES:-none}"
    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "  Inventory content"
    echo "  Saved copy : ${DAOS_INVENTORY_COPY}"
    echo "════════════════════════════════════════════════════════════════"
    if [[ -f "${DAOS_INVENTORY_COPY}" ]]; then
        cat "${DAOS_INVENTORY_COPY}"
    else
        echo "  [inventory copy not available]"
        echo "  Re-run the playbook to restore the saved copy."
    fi
    echo "════════════════════════════════════════════════════════════════"
fi
